# OIDC — consumed by upstream photoprism for browser/PWA login.
# WebDAV / 3rd-party clients use app-passwords generated in photoprism's account UI.
PHOTOPRISM_SITE_URL="{{ .AppUrl }}/"
PHOTOPRISM_OIDC_URI="{{ .AuthUrl }}"
PHOTOPRISM_OIDC_CLIENT="{{ .App }}"
PHOTOPRISM_OIDC_SECRET="{{ .ClientSecret }}"
PHOTOPRISM_OIDC_REGISTER="true"
PHOTOPRISM_OIDC_REDIRECT="true"
PHOTOPRISM_OIDC_SCOPES="openid profile email"
PHOTOPRISM_OIDC_WEBDAV="true"
PHOTOPRISM_OIDC_ROLE="admin"
