# LDAP — consumed by the syncloud ldap-webdav patch on the basic-auth path.
PHOTOPRISM_LDAP_ENABLED="true"
PHOTOPRISM_LDAP_URI="ldap://localhost:389"
PHOTOPRISM_LDAP_BIND_DN="cn={username},ou=users,dc=syncloud,dc=org"
PHOTOPRISM_LDAP_ADMIN_GROUP_DN="cn=syncloud,ou=groups,dc=syncloud,dc=org"
PHOTOPRISM_LDAP_ADMIN_GROUP_FILTER="(memberUid={username})"
PHOTOPRISM_LDAP_ADMIN_GROUP_ATTRIBUTE="memberUid"
PHOTOPRISM_LDAP_DEFAULT_USER_ROLE="visitor"

# OIDC — consumed by upstream photoprism for browser/PWA login.
PHOTOPRISM_SITE_URL="{{ .AppUrl }}/"
PHOTOPRISM_OIDC_URI="{{ .AuthUrl }}"
PHOTOPRISM_OIDC_CLIENT="photoprism"
PHOTOPRISM_OIDC_SECRET="{{ .ClientSecret }}"
PHOTOPRISM_OIDC_REGISTER="true"
PHOTOPRISM_OIDC_REDIRECT="true"
