PHOTOPRISM_LDAP_ENABLED="true"
PHOTOPRISM_LDAP_URI="ldap://localhost:389"
PHOTOPRISM_LDAP_BIND_DN="cn={username},ou=users,dc=syncloud,dc=org"
PHOTOPRISM_LDAP_ADMIN_GROUP_DN="cn=syncloud,ou=groups,dc=syncloud,dc=org"
PHOTOPRISM_LDAP_ADMIN_GROUP_FILTER="(memberUid={username})"
PHOTOPRISM_LDAP_ADMIN_GROUP_ATTRIBUTE="memberUid"
PHOTOPRISM_LDAP_DEFAULT_USER_ROLE="user"
