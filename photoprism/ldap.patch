diff --git a/internal/entity/auth_session_login_ldap.go b/internal/entity/auth_session_login_ldap.go
new file mode 100644
--- /dev/null
+++ b/internal/entity/auth_session_login_ldap.go
@@ -0,0 +1,119 @@
+package entity
+
+import (
+	"os"
+	"strings"
+
+	"github.com/go-ldap/ldap/v3"
+	"github.com/jinzhu/gorm"
+
+	"github.com/photoprism/photoprism/internal/auth/acl"
+	"github.com/photoprism/photoprism/pkg/authn"
+	"github.com/photoprism/photoprism/pkg/clean"
+	"github.com/photoprism/photoprism/pkg/i18n"
+)
+
+// authLdapIfEnabled binds against PHOTOPRISM_LDAP_URI when LDAP is enabled and,
+// on success, returns the matching local user (auto-creating one on first login).
+// The bool return signals whether the LDAP path was taken so the caller can
+// fall through to local auth otherwise.
+func authLdapIfEnabled(username, password string) (user *User, provider authn.ProviderType, method authn.MethodType, err error, handled bool) {
+	if os.Getenv("PHOTOPRISM_LDAP_ENABLED") != "true" {
+		return nil, authn.ProviderNone, authn.MethodUndefined, nil, false
+	}
+	provider = authn.ProviderLDAP
+	method = authn.MethodDefault
+	isAdmin, err := authLdap(username, password)
+	if err != nil {
+		return nil, provider, method, err, true
+	}
+	user = FindUserByName(username)
+	if user == nil {
+		user, err = createLdapUser(username, isAdmin)
+		if err != nil {
+			return nil, provider, method, err, true
+		}
+	} else if !isAdmin {
+		if err := migrateLdapUser(user); err != nil {
+			return nil, provider, method, err, true
+		}
+	}
+	user.UpdateLoginTime()
+	return user, provider, method, nil, true
+}
+
+// migrateLdapUser brings a pre-existing LDAP row up to the current
+// non-admin contract: PHOTOPRISM_LDAP_DEFAULT_USER_ROLE plus a per-user
+// BasePath. Old releases stored these accounts as RoleVisitor with no
+// BasePath, which left them unable to sign in to the web UI; this
+// upgrades them on next login. Idempotent.
+func migrateLdapUser(user *User) error {
+	desiredRole := os.Getenv("PHOTOPRISM_LDAP_DEFAULT_USER_ROLE")
+	if user.UserRole == desiredRole && user.BasePath != "" && user.CanLogin && user.WebDAV {
+		return nil
+	}
+	user.UserRole = desiredRole
+	user.CanLogin = true
+	user.WebDAV = true
+	user.SetBasePath("~")
+	if err := Db().Save(user).Error; err != nil {
+		log.Errorln("ldap migrate user error", err)
+		return err
+	}
+	log.Infof("ldap: migrated user %s to role %s", clean.LogQuote(user.Username()), desiredRole)
+	return nil
+}
+
+func authLdap(username, password string) (bool, error) {
+	conn, err := ldap.DialURL(os.Getenv("PHOTOPRISM_LDAP_URI"))
+	if err != nil {
+		log.Errorln("ldap dial error", err)
+		return false, i18n.Error(i18n.ErrInvalidCredentials)
+	}
+	defer conn.Close()
+	bindDn := strings.ReplaceAll(os.Getenv("PHOTOPRISM_LDAP_BIND_DN"), "{username}", username)
+	if err := conn.Bind(bindDn, password); err != nil {
+		log.Errorln("ldap bind error", err)
+		return false, i18n.Error(i18n.ErrInvalidCredentials)
+	}
+	return isLdapAdmin(conn, username)
+}
+
+func isLdapAdmin(conn *ldap.Conn, username string) (bool, error) {
+	req := ldap.NewSearchRequest(
+		os.Getenv("PHOTOPRISM_LDAP_ADMIN_GROUP_DN"),
+		ldap.ScopeWholeSubtree, ldap.DerefAlways, 0, 0, false,
+		strings.ReplaceAll(os.Getenv("PHOTOPRISM_LDAP_ADMIN_GROUP_FILTER"), "{username}", username),
+		[]string{os.Getenv("PHOTOPRISM_LDAP_ADMIN_GROUP_ATTRIBUTE")},
+		nil,
+	)
+	sr, err := conn.Search(req)
+	if err != nil {
+		log.Errorln("ldap admin search error", err)
+		return false, err
+	}
+	return len(sr.Entries) > 0, nil
+}
+
+func createLdapUser(username string, isAdmin bool) (*User, error) {
+	user := NewUser()
+	user.UserName = username
+	user.SuperAdmin = isAdmin
+	user.CanLogin = true
+	user.WebDAV = true
+	user.CanInvite = true
+	if isAdmin {
+		user.UserRole = acl.RoleAdmin.String()
+	} else {
+		user.UserRole = os.Getenv("PHOTOPRISM_LDAP_DEFAULT_USER_ROLE")
+		user.SetBasePath("~")
+	}
+	if err := Db().Transaction(func(tx *gorm.DB) error {
+		return tx.Create(user).Error
+	}); err != nil {
+		log.Errorln("ldap user save error", err)
+		return nil, err
+	}
+	log.Infof("ldap: added user %s", clean.LogQuote(user.Username()))
+	return user, nil
+}
